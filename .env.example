# Copie este arquivo para ".env" e preencha com seus próprios valores.
# NUNCA cometa o arquivo ".env" real no controle de versão.

# Chave de API do Google Gemini.
# Gere a sua gratuitamente em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=coloque_sua_chave_aqui

# Modelo do Gemini utilizado nas requisições.
# Consulte os modelos disponíveis em: https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL=gemini-3.5-flash

# Chave secreta usada internamente pelo Flask (sessões, CSRF, etc.).
FLASK_SECRET_KEY=troque-por-uma-chave-secreta-aleatoria

# Ativa o modo de debug do Flask (recarregamento automático e mensagens de erro detalhadas).
# Use "False" em produção.
FLASK_DEBUG=True

# Quantidade máxima de interações mantidas no histórico em memória.
MAX_HISTORY_ITEMS=50
