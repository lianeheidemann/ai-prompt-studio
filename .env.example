# Copie este arquivo para ".env" e preencha os valores necessários.
# Nunca envie o arquivo .env real ao controle de versão.

GEMINI_API_KEY=coloque_sua_chave_aqui
GEMINI_MODEL=gemini-3.5-flash

FLASK_SECRET_KEY=troque-por-uma-chave-secreta-aleatoria
FLASK_DEBUG=True

# Limites de entrada e do contexto conversacional.
MAX_PROMPT_LENGTH=10000
MAX_CONTEXT_MESSAGES=12
MAX_CONTEXT_CHARS=30000
MAX_REQUEST_BYTES=65536

# Limite simples por endereço IP e por janela de tempo.
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# Quantidade máxima salva no localStorage de cada navegador.
MAX_HISTORY_ITEMS=50
